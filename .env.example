# ==========================================
# CardioSync - Environment Configurations
# ==========================================

# Database Selection
# Options: sqlite, mysql, postgresql
DB_TYPE=sqlite

# SQLite Path (relative to project root, or absolute path)
DB_PATH=heart_disease.db

# External Database Settings
# Required if DB_TYPE is mysql or postgresql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=heart_disease
DB_USER=root
DB_PASSWORD=your_password

# Flask Application Settings
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=True
PORT=5000
